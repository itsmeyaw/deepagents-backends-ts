  "license": "MIT",
  "bugs": {
    "url": "https://github.com/itsmeyaw/deepagent-backends-ts/issues"
  },
  "homepage": "https://github.com/itsmeyaw/deepagent-backends-ts#readme",
  "packageManager": "pnpm@10.32.1",
  "devDependencies": {
    "@tsconfig/recommended": "^1.0.13",
    "@vitest/coverage-v8": "4.1.0",
    "lint-staged": "^16.4.0",
    "oxlint": "^1.56.0",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  },
  "peerDependencies": {
    "deepagents": "^1.8.0"
  }
