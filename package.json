{
  "name": "deepagent-backends-ts",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Collection of DeepAgent backends implemented in TypeScript",
  "scripts": {
    "format": "prettier --write .",
    "test": "pnpm -r --if-present test",
    "coverage": "pnpm -r --if-present coverage",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,cjs}": "pnpm run lint"
