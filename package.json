{
  "name": "deepagents-backends-ts",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Collection of DeepAgent backends implemented in TypeScript",
  "scripts": {
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "build": "pnpm -r --if-present build",
    "test": "pnpm -r --if-present test",
    "coverage": "pnpm -r --if-present coverage",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "lint-staged": "lint-staged",
    "release": "pnpm build && changeset publish",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,cjs,json,yml}": "pnpm run lint --fix && pnpm run format"
  },
  "keywords": [
    "deepagents",
    "ai",
    "llm",
    "typescript"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/itsmeyaw/deepagents-backends-ts.git"
  },
  "author": "Yudhistira Arief Wibowo <yudhistira.wibowo@itsmeyaw.id>",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/itsmeyaw/deepagents-backends-ts/issues"
  },
  "homepage": "https://github.com/itsmeyaw/deepagents-backends-ts#readme",
  "packageManager": "pnpm@10.32.1",
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@tsconfig/recommended": "^1.0.13",
    "@vitest/coverage-v8": "4.1.2",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "oxlint": "^1.56.0",
    "prettier": "^3.8.1",
    "tsdown": "^0.21.4",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  },
  "peerDependencies": {
    "deepagents": "^1.8.0"
  }
}
