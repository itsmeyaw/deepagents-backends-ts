{
  "name": "deepagents-s3-backend",
  "version": "1.8.6",
  "description": "S3 backend for DeepAgent in TypeScript",
  "scripts": {
    "build": "tsdown",
    "test": "vitest run",
    "coverage": "vitest run --coverage"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "types": "./dist/index.d.ts",
  "module": "./dist/index.js",
  "keywords": [
    "deepagents",
    "ai",
    "llm",
    "s3",
    "typescript"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/itsmeyaw/deepagents-backends-ts.git"
  },
  "author": "Yudhistira Arief Wibowo <yudhistira.wibowo@itsmeyaw.id>",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/itsmeyaw/deepagents-backends-ts/issues"
  },
  "homepage": "https://github.com/itsmeyaw/deepagents-backends-ts/tree/main/packages/deepagents-s3-backend#readme",
  "packageManager": "pnpm@10.32.1",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1012.0",
    "micromatch": "^4.0.8"
  },
  "peerDependencies": {
    "deepagents": "^1.8.0"
  },
  "devDependencies": {
    "@smithy/types": "^4.13.1",
    "@types/micromatch": "^4.0.10"
  },
  "readme": "README.md",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist/**/*"
  ]
}
